rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // REGLA PARA PRODUCTOS: Lectura pública para que el Arsenal cargue el catálogo.
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // REGLA PARA ACTIVACIONES: Cualquiera puede LEER (para validaciones de cliente),
    // pero nadie puede escribir ni borrar desde el navegador.
    match /activations/{clientId} {
      allow read: if true;
      allow write: if false;
    }
    
    // BLOQUEO GLOBAL: Cualquier otra colección nueva está cerrada por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}